<div style="
    background: url('/Images/restaurante.png?v=2') no-repeat center center;
    background-size: cover;
    min-height: 100vh;
">

    <div style="
        background: rgba(0,0,0,0.45);
        min-height: 100vh;
        padding: 110px 30px 30px 30px;
    ">

        <div style="max-width: 500px; margin: auto; color: white;">

       
            <div class="mb-3 p-3 rounded-4 d-flex justify-content-between align-items-center"
                 style="
                    background: rgba(255,255,255,0.08);
                    border: 1px solid rgba(255,255,255,0.15);
                    backdrop-filter: blur(6px);
                    max-width: 360px;
                    margin: 0 auto;
                 ">
                <div>
                    <div style="font-size:14px; opacity:0.7;">Clientes</div>
                    <div style="font-size:28px; font-weight:bold; line-height:1;">
                        @ViewBag.TotalClientes
                    </div>
                </div>

                <div style="font-size:26px;">👥</div>
            </div>

            <div class="mb-3 p-3 rounded-4 d-flex justify-content-between align-items-center"
                 style="
                    background: rgba(255,255,255,0.08);
                    border: 1px solid rgba(255,255,255,0.15);
                    backdrop-filter: blur(6px);
                    max-width: 360px;
                    margin: 0 auto;
                 ">
                <a asp-controller="Clientes" asp-action="ClientesConPremio" style="text-decoration:none;">

                    <div class="card-premio shadow-lg rounded-4 text-white text-center p-4">
                        <h5 class="mb-2">🎁 Premios para canjear</h5>
                        <h2 class="fw-bold">@ViewBag.ClientesConPremio</h2>
                        <p class="mb-0">Ver clientes con premio disponible</p>
                    </div>

                </a>

                <div style="font-size:26px;">🎁</div>
            </div>

            <div class="mb-3 p-3 rounded-4 d-flex justify-content-between align-items-center"
                 style="
                    background: rgba(255,255,255,0.08);
                    border: 1px solid rgba(255,255,255,0.15);
                    backdrop-filter: blur(6px);
                    max-width: 360px;
                    margin: 0 auto;
                 ">
                <div>
                    <div style="font-size:14px; opacity:0.7;">Premios canjeados</div>
                    <div style="font-size:28px; font-weight:bold;">
                        @ViewBag.PremiosCanjeados
                    </div>
                </div>

                <div style="font-size:26px;">⭐</div>
            </div>

            <div class="d-grid gap-3">
                <a asp-action="Create"
                   class="btn btn-light btn-lg rounded-pill"
                   style="font-weight:600; padding:15px;">
                    Nuevo cliente
                </a>

                <a asp-action="Index"
                   class="btn btn-outline-light btn-lg rounded-pill"
                   style="padding:15px;">
                    Ver clientes
                </a>

                <a asp-controller="Clientes" asp-action="EscanearQR"
                   style="
                        display:block;
                        text-align:center;
                        padding:18px;
                        margin-bottom:10px;
                        border-radius:20px;
                        background: rgba(255,255,255,0.15);
                        color:white;
                        text-decoration:none;
                        font-weight:bold;
                        font-size:18px;
                   ">
                    📷 Escanear QR
                </a>
            </div>

        </div>

    </div>

</div>


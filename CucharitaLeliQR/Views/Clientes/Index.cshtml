@model List<CucharitaLeliQR.Models.Cliente>

<div style="
    background: url('/Images/restaurant.png') no-repeat center center;
    background-size: cover;
    min-height: 100vh;
">
    <div style="
        background: rgba(0,0,0,0.45);
        min-height: 100vh;
        padding: 30px;
    ">
        <div style="max-width: 550px; margin:auto; color:white;">

            <h3 class="text-center mb-4">Clientes</h3>

            @foreach (var item in Model)
            {
                <div id="cliente-@item.Id"
                     class="mb-4 p-4 rounded-4"
                     style="background: rgba(255,255,255,0.12); backdrop-filter: blur(12px);">

                    <div class="d-flex justify-content-between align-items-center">
                        <h4 style="margin:0;">@item.Nombre</h4>

                        <div id="puntos-@item.Id" style="font-size:18px; transition:0.2s;">
                            ⭐ @item.Puntos
                        </div>
                    </div>

                    <div id="premios-@item.Id" style="font-size:13px; color:#d4af37;">
                        🎁 @item.PremiosCanjeados canjeados
                    </div>

                    <div id="fecha-@item.Id" style="font-size:14px; opacity:0.7;">
                        @if (item.UltimoEscaneo != null)
                        {
                            <span>Último: @item.UltimoEscaneo.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        }
                        else
                        {
                            <span>Sin escaneos</span>
                        }
                    </div>

                    <div class="d-flex gap-3 mt-3 flex-wrap" id="acciones-@item.Id">

                        <button type="button"
                                class="btn btn-warning btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#qrModal"
                                onclick="mostrarQR(@item.Id, '@item.Nombre')">
                            Ver QR
                        </button>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-warning btn-lg px-4">
                            ✏ Editar
                        </a>

                        @if (item.Puntos < 100)
                        {
                            <button type="button"
                                    onclick="sumarPuntos(@item.Id)"
                                    class="btn btn-light btn-lg px-4"
                                    id="btn-sumar-@item.Id">
                                +20
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    onclick="entregarPremio(@item.Id)"
                                    class="btn btn-warning btn-lg px-4"
                                    id="btn-premio-@item.Id">
                                🎁 Premio
                            </button>
                        }

                        <a asp-action="Eliminar"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-danger btn-lg px-4"
                           onclick="return confirm('¿Eliminar cliente?');">
                            🗑
                        </a>

                    </div>
                </div>
            }

            <div class="mt-4 d-grid">
                <a asp-action="Dashboard" class="btn btn-outline-light btn-lg">
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>

<!-- MODAL QR -->
<div class="modal fade" id="qrModal" tabindex="-1" aria-labelledby="qrModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:20px; overflow:hidden; background:#1c1c1c; color:white;">

            <div class="modal-header border-0" style="background: #111;">
                <h5 class="modal-title" id="qrModalLabel">Código QR del cliente</h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>

            <div class="modal-body text-center" style="padding:30px;">
                <h5 id="nombreClienteQR" class="mb-3"></h5>

                <div style="
                    background:white;
                    border-radius:18px;
                    padding:18px;
                    display:inline-block;
                    box-shadow: 0 8px 20px rgba(0,0,0,0.35);
                ">
                    <img id="imagenQR"
                         src=""
                         alt="Código QR del cliente"
                         class="img-fluid"
                         style="max-width:250px;" />
                </div>

                <p class="mt-3 mb-0" style="opacity:0.8; font-size:14px;">
                    Este código pertenece únicamente al cliente seleccionado.
                </p>
            </div>

            <div class="modal-footer border-0" style="background:#111;">
                <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

<!-- MODAL RESULTADO -->
<div id="modalResultado" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.8);
    z-index:9999;
    justify-content:center;
    align-items:center;
">
    <div style="
        background:white;
        border-radius:20px;
        padding:30px;
        width:90%;
        max-width:400px;
        text-align:center;
    ">
        <h2 id="modalTitulo" style="color:green;">Resultado</h2>
        <h4 id="modalNombre"></h4>
        <h3 id="modalPuntos"></h3>
        <p id="modalMensaje"></p>

        <button type="button" onclick="cerrarModal()" class="btn btn-dark mt-3">
            Cerrar
        </button>
    </div>
</div>

<script>
    function mostrarQR(id, nombre) {
        document.getElementById("nombreClienteQR").innerText = nombre;
        document.getElementById("imagenQR").src = '/Clientes/GenerarQR/' + id;
    }

    function sumarPuntos(id) {
        fetch(`/Clientes/SumarPuntosAjax?id=${id}`)
            .then(response => response.json())
            .then(data => {
                if (!data || data.mensaje === "Error") {
                    alert("No se pudo sumar puntos.");
                    return;
                }

                let puntosDiv = document.getElementById("puntos-" + id);
                puntosDiv.innerText = "⭐ " + data.puntos;

                puntosDiv.style.transform = "scale(1.2)";
                setTimeout(() => {
                    puntosDiv.style.transform = "scale(1)";
                }, 200);

                let fechaTexto = data.fecha ? data.fecha : "Sin escaneos";
                document.getElementById("fecha-" + id).innerText = "Último: " + fechaTexto;

                if (data.puntos >= 100) {
                    puntosDiv.style.color = "#d4af37";

                    let contenedor = document.getElementById("acciones-" + id);

                    contenedor.innerHTML = `
                        <button type="button"
                                class="btn btn-warning btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#qrModal"
                                onclick="mostrarQR(${id}, '${data.nombre}')">
                            Ver QR
                        </button>

                        <a href="/Clientes/Edit/${id}" class="btn btn-outline-warning btn-lg px-4">
                            ✏ Editar
                        </a>

                        <button type="button"
                                onclick="entregarPremio(${id})"
                                class="btn btn-warning btn-lg px-4"
                                id="btn-premio-${id}">
                            🎁 Premio
                        </button>

                        <a href="/Clientes/Eliminar/${id}"
                           class="btn btn-outline-danger btn-lg px-4"
                           onclick="return confirm('¿Eliminar cliente?');">
                            🗑
                        </a>
                    `;
                }

                document.getElementById("modalTitulo").innerText = "+20 puntos agregados";
                document.getElementById("modalNombre").innerText = "Cliente: " + data.nombre;
                document.getElementById("modalPuntos").innerText = "⭐ " + data.puntos;
                document.getElementById("modalMensaje").innerText = data.mensaje;

                document.getElementById("modalResultado").style.display = "flex";
            })
            .catch(error => {
                console.error("Error en sumarPuntos:", error);
                alert("Error al sumar puntos.");
            });
    }

    function entregarPremio(id) {
        fetch(`/Clientes/EntregarPremioAjax?id=${id}`)
            .then(response => response.json())
            .then(data => {
                if (!data || data.mensaje === "Error") {
                    alert("No se pudo entregar el premio.");
                    return;
                }

                let premiosDiv = document.getElementById("premios-" + id);
                if (premiosDiv) {
                    premiosDiv.innerText = "🎁 " + data.premios + " canjeados";
                }

                document.getElementById("puntos-" + id).innerText = "⭐ 0";
                document.getElementById("puntos-" + id).style.color = "white";
                document.getElementById("fecha-" + id).innerText = "Último: " + data.fecha;

                let contenedor = document.getElementById("acciones-" + id);

                contenedor.innerHTML = `
                    <button type="button"
                            class="btn btn-warning btn-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#qrModal"
                            onclick="mostrarQR(${id}, '${data.nombre}')">
                        Ver QR
                    </button>

                    <a href="/Clientes/Edit/${id}" class="btn btn-outline-warning btn-lg px-4">
                        ✏ Editar
                    </a>

                    <button type="button"
                            onclick="sumarPuntos(${id})"
                            class="btn btn-light btn-lg px-4"
                            id="btn-sumar-${id}">
                        +20
                    </button>

                    <a href="/Clientes/Eliminar/${id}"
                       class="btn btn-outline-danger btn-lg px-4"
                       onclick="return confirm('¿Eliminar cliente?');">
                        🗑
                    </a>
                `;

                document.getElementById("modalTitulo").innerText = "🎁 Premio entregado";
                document.getElementById("modalNombre").innerText = "Cliente: " + data.nombre;
                document.getElementById("modalPuntos").innerText = "Puntos reiniciados";
                document.getElementById("modalMensaje").innerText = "✅ Todo correcto";

                document.getElementById("modalResultado").style.display = "flex";
            })
            .catch(error => {
                console.error("Error en entregarPremio:", error);
                alert("Error al entregar premio.");
            });
    }

    function cerrarModal() {
        document.getElementById("modalResultado").style.display = "none";
    }
</script>
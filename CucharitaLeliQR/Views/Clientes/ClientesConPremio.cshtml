@model List<CucharitaLeliQR.Models.Cliente>

@{
    ViewData["Title"] = "Clientes con premio";
}

<div style="
    background: url('/Images/restaurante.png') no-repeat center center fixed;
    background-size: cover;
    min-height: 100vh;
    padding: 110px 20px 30px 20px;
    ">
    <div style="
        background: rgba(0,0,0,0.55);
        min-height: 100vh;
        padding: 30px;
        border-radius: 20px;
        ">

        <div class="container">
            <div class="text-center mb-4">
                <h2 style="color:white; font-weight:bold;">🎁 Clientes con premio disponible</h2>
                <p style="color:#ddd;">Aquí se muestran los clientes que ya pueden canjear premio.</p>
            </div>

            @if (Model != null && Model.Count > 0)
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-6 col-lg-4" id="cliente-premio-@item.Id">
                            <div class="card border-0 shadow-lg rounded-4 h-100"
                                 style="background: rgba(255,255,255,0.10); backdrop-filter: blur(8px); color:white;">
                                <div class="card-body text-center p-4">

                                    <h4 class="fw-bold mb-3">@item.Nombre</h4>

                                    <p class="mb-2">
                                        <strong>Puntos:</strong> @item.Puntos
                                    </p>

                                    <p class="mb-3">
                                        <strong>Premios canjeados:</strong> @item.PremiosCanjeados
                                    </p>

                                    <button type="button"
                                            onclick="entregarPremio(@item.Id)"
                                            class="btn btn-warning rounded-pill px-4 fw-bold">
                                        Canjear premio
                                    </button>

                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light text-center rounded-4 shadow-sm">
                    No hay clientes con premio disponible en este momento.
                </div>
            }

            <div class="text-center mt-4">
                <a asp-controller="Clientes" asp-action="Dashboard" class="btn btn-light rounded-pill px-4">
                    Volver al Menú principal
                </a>
            </div>
        </div>

    </div>
</div>

<!-- MODAL RESULTADO -->
<div id="modalResultado" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.8);
    z-index:9999;
    justify-content:center;
    align-items:center;
    ">
    <div style="
        background:white;
        border-radius:20px;
        padding:30px;
        width:90%;
        max-width:400px;
        text-align:center;
        ">
        <h2 id="modalTitulo" style="color:green;">Resultado</h2>
        <h4 id="modalNombre"></h4>
        <h3 id="modalPuntos"></h3>
        <p id="modalMensaje"></p>

        <button type="button" onclick="cerrarModal()" class="btn btn-dark mt-3">
            Cerrar
        </button>
    </div>
</div>

<script>
    function entregarPremio(id) {
        const url = '@Url.Action("EntregarPremioAjax", "Clientes")' + '?id=' + id;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (!data || data.mensaje === "Error") {
                    alert("No se pudo entregar el premio.");
                    return;
                }

                document.getElementById("modalTitulo").innerText = "🎁 Premio entregado";
                document.getElementById("modalNombre").innerText = "Cliente: " + data.nombre;
                document.getElementById("modalPuntos").innerText = "Puntos reiniciados";
                document.getElementById("modalMensaje").innerText = "✅ Todo correcto";

                document.getElementById("modalResultado").style.display = "flex";
            })
            .catch(error => {
                console.error("Error en entregarPremio:", error);
                alert("Error al entregar premio.");
            });
    }

    function cerrarModal() {
        document.getElementById("modalResultado").style.display = "none";
        window.location.href = '@Url.Action("ClientesConPremio", "Clientes")';
    }
</script>
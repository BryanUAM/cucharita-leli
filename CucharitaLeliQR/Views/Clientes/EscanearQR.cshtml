@{
    ViewData["Title"] = "Escanear QR";
}

<script src="https://unpkg.com/html5-qrcode"></script>

<div style="
    background: #000;
    min-height: 100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    color:white;
    text-align:center;
    padding:20px;
">

    <h4 style="margin-bottom:10px;">📷 Escanear cliente</h4>
    <p style="opacity:0.6; font-size:14px;">Coloque el código dentro del cuadro</p>

    <!-- CONTENEDOR ESCANER -->
    <div style="
        position: relative;
        width: 280px;
        height: 280px;
        margin-top:20px;
    ">

        <!-- MARCO -->
        <div style="
            position:absolute;
            width:100%;
            height:100%;
            border:2px solid rgba(255,255,255,0.2);
            border-radius:20px;
        "></div>

        <!-- ESQUINAS -->
        <div style="position:absolute; top:0; left:0; width:40px; height:40px; border-top:4px solid #d4af37; border-left:4px solid #d4af37; border-radius:10px;"></div>
        <div style="position:absolute; top:0; right:0; width:40px; height:40px; border-top:4px solid #d4af37; border-right:4px solid #d4af37; border-radius:10px;"></div>
        <div style="position:absolute; bottom:0; left:0; width:40px; height:40px; border-bottom:4px solid #d4af37; border-left:4px solid #d4af37; border-radius:10px;"></div>
        <div style="position:absolute; bottom:0; right:0; width:40px; height:40px; border-bottom:4px solid #d4af37; border-right:4px solid #d4af37; border-radius:10px;"></div>

        <!-- LÍNEA ANIMADA -->
        <div style="
            position:absolute;
            width:100%;
            height:2px;
            background:#d4af37;
            top:0;
            animation: scan 2s infinite;
        "></div>

        <!-- CÁMARA -->
        <div id="reader" style="
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    border-radius:20px;
    overflow:hidden;
"></div>
        </div>

    <div id="modalResultadoQR" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.75);
    z-index:9999;
    justify-content:center;
    align-items:center;
">
        <div style="
        width:90%;
        max-width:400px;
        background:#111;
        border-radius:20px;
        padding:25px;
        text-align:center;
        color:white;
    ">
            <h2 id="tituloResultadoQR">Resultado</h2>
            <p id="nombreResultadoQR"></p>
            <h3 id="puntosResultadoQR"></h3>
            <p id="faltanResultadoQR"></p>

            <button onclick="cerrarModalResultadoQR()" class="btn btn-warning mt-3">
                Cerrar
            </button>
        </div>
    </div>

    <!-- ESTADO -->
    <p id="estado" style="margin-top:20px; opacity:0.7;">
        Esperando escaneo...
    </p>

    <!-- BOTÓN VOLVER -->
    <a asp-controller="Clientes" asp-action="Dashboard"
       style="
            margin-top:25px;
            padding:10px 20px;
            border-radius:20px;
            background: rgba(255,255,255,0.08);
            color:white;
            text-decoration:none;
            font-size:14px;
        ">
        ← Volver al menú
    </a>

</div>

<!-- ANIMACIÓN -->
<style>
    @@keyframes scan {
        0% {
            top: 0;
        }

        50% {
            top: 90%;
        }

        100% {
            top: 0;
        }
    }
</style>

<script>
    function onScanSuccess(decodedText, decodedResult) {

        document.getElementById("estado").innerText = "✅ Código detectado";

        html5QrCode.stop();

        fetch('/Clientes/ProcesarEscaneoInterno', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: 'codigo=' + encodeURIComponent(decodedText)
        })
        .then(response => response.json())
            .then(data => {
        if (data.ok) {
            document.getElementById("tituloResultadoQR").innerText = "✅ Puntos agregados";
            document.getElementById("nombreResultadoQR").innerText = "Cliente: " + data.nombre;
            document.getElementById("puntosResultadoQR").innerText = "⭐ " + data.puntos;
            document.getElementById("faltanResultadoQR").innerText = "Faltan: " + data.faltan + " puntos";
        } else {
            document.getElementById("tituloResultadoQR").innerText = "❌ Error";
            document.getElementById("nombreResultadoQR").innerText = data.mensaje;
            document.getElementById("puntosResultadoQR").innerText = "";
            document.getElementById("faltanResultadoQR").innerText = "";
        }

        document.getElementById("modalResultadoQR").style.display = "flex";
    })
        .catch(error => {
            console.log("Error al procesar escaneo:", error);
            document.getElementById("estado").innerText = "❌ Error al procesar el código";

            setTimeout(() => {
                html5QrCode.start(
                    cameraIdGlobal,
                    {
                        fps: 10,
                        qrbox: 250
                    },
                    onScanSuccess,
                    onScanError
                );
            }, 2000);
        });
    }

    function onScanError(errorMessage) {
        // silencioso
    }

    let html5QrCode = new Html5Qrcode("reader");
    let cameraIdGlobal = null;

    Html5Qrcode.getCameras().then(devices => {

        if (devices && devices.length) {

            let backCamera = devices.find(d =>
                d.label.toLowerCase().includes("back") ||
                d.label.toLowerCase().includes("trasera")
            );

            cameraIdGlobal = backCamera ? backCamera.id : devices[0].id;

            html5QrCode.start(
                cameraIdGlobal,
                {
                    fps: 10,
                    qrbox: 250
                },
                onScanSuccess,
                onScanError
            );
        }

    }).catch(err => {
        console.log("Error cámara:", err);
        document.getElementById("estado").innerText = "❌ No se pudo acceder a la cámara";
    });

        function cerrarModalResultadoQR() {
        document.getElementById("modalResultadoQR").style.display = "none";

        html5QrCode.start(
            cameraIdGlobal,
            {
                fps: 10,
                qrbox: 250
            },
            onScanSuccess,
            onScanError
        );
    }
</script>
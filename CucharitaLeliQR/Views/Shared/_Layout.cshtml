<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CucharitaLeliQR</title>
    <style>
        .nav-link {
            transition: color 0.3s ease;
        }

            .nav-link:hover {
                color: #d4af37 !important; /* dorado elegante */
            }

        .navbar-brand:hover {
            color: #d4af37 !important;
        }
    </style>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>

<body style="margin:0; padding:0;">

    <!-- 🔥 NAVBAR PREMIUM -->
    <nav class="navbar navbar-expand-sm navbar-dark" style="
        background: rgba(0,0,0,0.75);
        position: absolute;
        width: 100%;
        z-index: 10;
    ">
        <div class="container-fluid">

            <!-- LOGO / NOMBRE -->
            <a class="navbar-brand text-white fw-bold" asp-controller="Home" asp-action="Index">
                🍽️ Cucharita de Leli
            </a>

            <!-- BOTÓN MÓVIL -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENÚ -->
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                            Inicio
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Clientes" asp-action="Dashboard">
                            Clientes
                        </a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- 🔥 CONTENIDO -->
    <div>
        @RenderBody()
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>